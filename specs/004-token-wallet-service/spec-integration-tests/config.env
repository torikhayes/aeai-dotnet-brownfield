# =============================================================================
# config.env — Shared configuration for feature 004 test scripts
#
# USAGE:
#   1. Edit the values below to match your running Aspire stack
#   2. Find PaymentProcessor URL: Aspire dashboard → payment-processor → endpoint
#   3. Find Identity URL:         Aspire dashboard → identity-api → endpoint
#   4. Find PG connection string: Aspire dashboard → postgres → Connection String
#
# All scripts source this file automatically via:
#   source "$(dirname "$0")/config.env"
# =============================================================================

# PaymentProcessor base URL (no trailing slash)
# Aspire assigns a dynamic port each run — find it from the Aspire dashboard
# or run: ps aux | grep PaymentProcessor | grep -o 'ASPNETCORE_URLS=[^ ]*'
# Example standalone: http://localhost:5226
PP="${PP:-http://localhost:62699}"

# Identity.API base URL (no trailing slash)
# Example: https://localhost:5243
IDENTITY="${IDENTITY:-https://localhost:62659}"

# Postgres connection string (host/user/password only — scripts append /tokendb)
# Example: "host=localhost port=5432 user=postgres password=yourpassword"
# Or DSN format: "postgresql://postgres:yourpassword@localhost:5432"
PG_CONN="${PG_CONN:-postgresql://postgres:%28PBxp4Fy.0~%7BjU0vTBsX%2BQ@localhost:32772}"

# Alice's JWT — populated by get-token.sh, or override here
TOKEN="${TOKEN:-}"

# Bob's JWT — populated by get-bob-token.sh, or override here
BOB_TOKEN="${BOB_TOKEN:-}"

# Alice's Identity sub claim — populated by get-alice-id.sh, or override here
ALICE_ID="${ALICE_ID:-}"

# ---------------------------------------------------------------------------
# Auto-load tokens from cache files if env vars are empty
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -z "$TOKEN" && -f "$SCRIPT_DIR/.alice_token" ]]; then
  TOKEN="$(cat "$SCRIPT_DIR/.alice_token")"
fi

if [[ -z "$BOB_TOKEN" && -f "$SCRIPT_DIR/.bob_token" ]]; then
  BOB_TOKEN="$(cat "$SCRIPT_DIR/.bob_token")"
fi

if [[ -z "$ALICE_ID" && -f "$SCRIPT_DIR/.alice_id" ]]; then
  ALICE_ID="$(cat "$SCRIPT_DIR/.alice_id")"
fi
